<?xml version="1.0" encoding="utf-8"?>
<objectAnimator xmlns:android="http://schemas.android.com/apk/res/android"
    android:propertyName="rotation"
    android:duration="1200"
    android:valueFrom="0"
    android:valueTo="0"
    android:valueType="floatType"
    android:repeatCount="infinite"
    android:repeatMode="restart"
    android:interpolator="@android:anim/accelerate_decelerate_interpolator">
    <propertyValuesHolder
        android:propertyName="rotation"
        android:valueType="floatType">
        <keyframe android:fraction="0.0" android:value="0" />
        <keyframe android:fraction="0.15" android:value="20" />
        <keyframe android:fraction="0.30" android:value="-20" />
        <keyframe android:fraction="0.45" android:value="12" />
        <keyframe android:fraction="0.60" android:value="-12" />
        <keyframe android:fraction="0.75" android:value="0" />
        <keyframe android:fraction="1.0" android:value="0" />
    </propertyValuesHolder>
</objectAnimator>
