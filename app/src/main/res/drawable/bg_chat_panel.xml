<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Background Color (Tinted Red) -->
    <item>
        <color android:color="@color/chat_background"/>
    </item>

    <!-- ECG Pattern Layer (CRASH FIX: Use item, not bitmap for vectors) -->
    <item
        android:drawable="@drawable/ic_ecg_pulse_line"
        android:gravity="center"
        android:width="200dp"
        android:height="48dp"
        android:tint="@color/chat_pattern_tint"/>
        
    <item
        android:drawable="@drawable/ic_ecg_pulse_line"
        android:gravity="top"
        android:top="150dp"
        android:width="200dp"
        android:height="48dp"
        android:tint="@color/chat_pattern_tint"/>

    <item
        android:drawable="@drawable/ic_ecg_pulse_line"
        android:gravity="bottom"
        android:bottom="150dp"
        android:width="200dp"
        android:height="48dp"
        android:tint="@color/chat_pattern_tint"/>
</layer-list>
