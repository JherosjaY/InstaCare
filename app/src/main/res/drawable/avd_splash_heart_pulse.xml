<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/ic_launcher_custom_heart_vector">

    <!-- 1. Heart Pulse Animation (Breathe) -->
    <target android:name="heart_content">
        <aapt:attr name="android:animation" xmlns:aapt="http://schemas.android.com/aapt">
            <set android:ordering="together">
                <objectAnimator
                    android:duration="800"
                    android:propertyName="scaleX"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:valueFrom="1.0"
                    android:valueTo="1.05"
                    android:interpolator="@android:interpolator/accelerate_decelerate" />
                <objectAnimator
                    android:duration="800"
                    android:propertyName="scaleY"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:valueFrom="1.0"
                    android:valueTo="1.05"
                    android:interpolator="@android:interpolator/accelerate_decelerate" />
            </set>
        </aapt:attr>
    </target>

    <!-- 2. ECG Line Chasing Tail Animation -->
    <target android:name="ecg_path">
        <aapt:attr name="android:animation" xmlns:aapt="http://schemas.android.com/aapt">
            <set android:ordering="sequentially">
                <!-- Chasing tail effect:
                     Stroke starts at 0 len.
                     Start increasing End (Draws line).
                     Then increasing Start (Erases line from back).
                -->
                <set android:ordering="together">
                    <objectAnimator
                        android:duration="1200"
                        android:propertyName="trimPathEnd"
                        android:valueFrom="0"
                        android:valueTo="1"
                        android:valueType="floatType"
                        android:repeatCount="infinite"
                        android:interpolator="@android:anim/linear_interpolator"/>
                    
                    <objectAnimator
                        android:startOffset="300"
                        android:duration="1200"
                        android:propertyName="trimPathStart"
                        android:valueFrom="0"
                        android:valueTo="1"
                        android:valueType="floatType"
                        android:repeatCount="infinite"
                        android:interpolator="@android:anim/linear_interpolator"/>
                </set>
            </set>
        </aapt:attr>
    </target>

</animated-vector>
