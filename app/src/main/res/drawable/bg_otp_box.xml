<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused State -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_card"/>
            <stroke android:width="2dp" android:color="@color/primary"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <!-- Enabled State -->
    <item android:state_enabled="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_card"/>
            <stroke android:width="1.5dp" android:color="@color/input_outline_default"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <!-- Disabled State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_card"/>
            <stroke android:width="1dp" android:color="#E5E7EB"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
</selector>
