<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Summary Stats (Top Grid) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border"
                app:cardBackgroundColor="@color/surface_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tvEvacuationCount" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="24sp" android:textStyle="bold" android:textColor="#F59E0B"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Evacuations Managed" android:textSize="10sp" android:textColor="@color/text_secondary"
                        android:textAllCaps="true" android:letterSpacing="0.05" android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border"
                app:cardBackgroundColor="@color/surface_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tvSosCount" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="24sp" android:textStyle="bold" android:textColor="#2563EB"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SOS Alerts in Zone" android:textSize="10sp" android:textColor="@color/text_secondary"
                        android:textAllCaps="true" android:letterSpacing="0.05" android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border"
                app:cardBackgroundColor="@color/surface_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tvEndorsementCount" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="24sp" android:textStyle="bold" android:textColor="#3B82F6"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Endorsements Reviewed" android:textSize="10sp" android:textColor="@color/text_secondary"
                        android:textAllCaps="true" android:letterSpacing="0.05" android:gravity="center"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Ranking Sections omitted for Barangay (as per user request) -->

        <!-- Detailed Audit Log -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Audit Chronology"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tvLogCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 entries"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- Filter Chips - Single Line Scrollable -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:scrollbars="none"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLogAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        android:textColor="@color/white"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:checked="true"
                        app:chipBackgroundColor="@color/primary_light"
                        app:chipCornerRadius="8dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLogEvacuation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Evacuations"
                        android:textColor="#64748B"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="#F1F5F9"
                        app:chipCornerRadius="8dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLogEndorsement"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Endorsements"
                        android:textColor="#64748B"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="#F1F5F9"
                        app:chipCornerRadius="8dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLogSos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SOS Alerts"
                        android:textColor="#64748B"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="#F1F5F9"
                        app:chipCornerRadius="8dp"/>

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border"
                app:cardBackgroundColor="@color/surface_card">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="200dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvLogs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"/>

                    <!-- Empty State -->
                    <LinearLayout
                        android:id="@+id/emptyStateLogs"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="gone"
                        android:padding="40dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_alert_triangle"
                            app:tint="@color/primary"
                            android:alpha="0.8"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No Activity Logs"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
