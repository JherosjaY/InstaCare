<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp">

    <!-- Bot Message (Left) -->
    <LinearLayout
        android:id="@+id/llBotMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginEnd="64dp"
        android:orientation="vertical">
        
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dashboard_card_border">
            
            <TextView
                android:id="@+id/tvBotText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Hi there!"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:typeface="sans"
                android:fontFamily="sans-serif-medium"
                android:textStyle="italic"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- User Message (Right) -->
    <LinearLayout
        android:id="@+id/llUserMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="64dp"
        android:orientation="vertical"
        android:visibility="gone">
        
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/primary"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            
            <TextView
                android:id="@+id/tvUserText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Hello Cara!"
                android:textColor="@android:color/white"
                android:textSize="14sp"/>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</LinearLayout>
