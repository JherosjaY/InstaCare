<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/guide_detail_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        android:background="@drawable/bg_topbar_surface_rounded"
        android:elevation="4dp">

        <TextView
            android:id="@+id/setupTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup Your Dashboard"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>

        <TextView
            android:id="@+id/setupSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Let's personalize your experience"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Stepper Timeline (Horizontal) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="20dp"
        android:paddingHorizontal="40dp">

        <!-- Step 1 Circle -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp">
            <View
                android:id="@+id/stepCircle1"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_step_active"/>
            <TextView
                android:id="@+id/stepText1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="1"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </FrameLayout>

        <!-- Line 1-2 -->
        <View
            android:id="@+id/stepLine1"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:layout_marginHorizontal="8dp"
            android:background="@color/stepper_inactive"/>

        <!-- Step 2 Circle -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp">
            <View
                android:id="@+id/stepCircle2"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_step_inactive"/>
            <TextView
                android:id="@+id/stepText2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/stepper_inactive_text"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </FrameLayout>

        <!-- Line 2-3 -->
        <View
            android:id="@+id/stepLine2"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:layout_marginHorizontal="8dp"
            android:background="@color/stepper_inactive"/>

        <!-- Step 3 Circle -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp">
            <View
                android:id="@+id/stepCircle3"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_step_inactive"/>
            <TextView
                android:id="@+id/stepText3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/stepper_inactive_text"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </FrameLayout>
    </LinearLayout>

    <!-- Step Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- STEP 1: Profile Photo -->
        <LinearLayout
            android:id="@+id/step1Content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Your Photo"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Help others recognize you"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="32dp"/>

            <!-- Avatar Circle with Camera Overlay -->
            <FrameLayout
                android:layout_width="164dp"
                android:layout_height="164dp"
                android:layout_gravity="center"
                android:clipChildren="false"
                android:clipToPadding="false">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/profileAvatar"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:src="@drawable/profile_placeholder"
                    android:background="@color/input_outline_default"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeWidth="3dp"
                    app:strokeColor="@color/primary"/>

                <!-- Camera Badge -->
                <FrameLayout
                    android:id="@+id/cameraBadge"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginBottom="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_camera_badge"
                    android:elevation="4dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera_white"
                        app:tint="@android:color/white"/>
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Tap to upload photo"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <!-- STEP 2: Personal Info -->
        <LinearLayout
            android:id="@+id/step2Content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm Your Info"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Make sure everything looks right"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/setupNameLayout"
                style="@style/InstaInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Full Name"
                android:layout_marginBottom="16dp"
                app:startIconDrawable="@drawable/ic_user"
                app:startIconTint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/setupNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName|textCapWords"
                    android:padding="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/setupEmailLayout"
                style="@style/InstaInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:layout_marginBottom="16dp"
                app:startIconDrawable="@drawable/ic_mail"
                app:startIconTint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/setupEmailInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:padding="16dp"
                    android:enabled="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/setupPhoneLayout"
                style="@style/InstaInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Phone"
                android:layout_marginBottom="16dp"
                app:startIconDrawable="@drawable/ic_phone"
                app:startIconTint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/setupPhoneInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:padding="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- STEP 3: Complete -->
        <LinearLayout
            android:id="@+id/step3Content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/completeIcon"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/avd_check_circle"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="You're All Set!"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Your dashboard is ready. Start exploring InstaCare and stay safe!"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:paddingBottom="32dp"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Back"
            android:textSize="16sp"
            android:visibility="gone"
            app:cornerRadius="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextButton"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:paddingHorizontal="48dp"
            android:text="Next"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            app:iconGravity="textEnd"
            app:iconTint="@android:color/white"/>
    </LinearLayout>
</LinearLayout>
