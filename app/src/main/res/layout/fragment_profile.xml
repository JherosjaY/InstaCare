<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/guide_detail_background">

    <!-- Fixed Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="@drawable/bg_header_rounded"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Profile"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage your account"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>
            
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">





        <!-- Profile Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/InstaCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/guide_detail_surface"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dashboard_card_border"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">
                        <ImageView
                            android:id="@+id/profileImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/profile_placeholder"
                            android:scaleType="centerCrop"/>
                    </com.google.android.material.card.MaterialCardView>
                    
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/editProfileImageBtn"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"
                        app:cardCornerRadius="14dp"
                        app:cardBackgroundColor="@color/primary"
                        app:strokeWidth="1dp"
                        app:strokeColor="@android:color/white">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_edit"
                            app:tint="@android:color/white"/>
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="20dp">
                    <TextView
                        android:id="@+id/profileNameText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Alex Thompson"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:textColor="?attr/colorOnSurface"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="14sp"
                        app:autoSizeMaxTextSize="20sp"
                        app:autoSizeStepGranularity="1sp"/>
                    <TextView
                        android:id="@+id/profileEmailText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="alex.t@example.com"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/profilePhoneText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+1 234 567 890"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>


            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Medical ID Title & Edit Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Medical ID"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="?attr/colorOnSurface"/>
                
            <ImageView
                android:id="@+id/btnEditMedicalInfo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_edit"
                app:tint="?attr/colorOnSurface"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>
        
        <com.google.android.material.card.MaterialCardView
            style="@style/InstaCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/guide_detail_surface"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dashboard_card_border"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Split Row: Blood Type & Sex -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- Blood Type -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/medical_blood_bg"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BLOOD TYPE"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/medical_blood_text"/>
                            <TextView
                                android:id="@+id/textBloodType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/medical_blood_value"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Sex -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/medical_phys_bg"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SEX"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/medical_phys_text"/>
                            <TextView
                                android:id="@+id/textSex"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/medical_phys_value"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Medical Conditions (Full width) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/medical_cond_bg"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MEDICAL CONDITIONS"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/medical_cond_text"/>
                        <TextView
                            android:id="@+id/textMedicalConditions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/medical_cond_value"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Medications (Full width) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/medical_meds_bg"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MEDICATIONS"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/medical_meds_text"/>
                        <TextView
                            android:id="@+id/textMedications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/medical_meds_value"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Allergies & Reactions (Full width) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/medical_allergy_bg"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALLERGIES &amp; REACTIONS"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/medical_allergy_text"/>
                        <TextView
                            android:id="@+id/textAllergies"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/medical_allergy_value"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Bottom Row: Weight & Height -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Weight -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/medical_info_divider"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WEIGHT"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/medical_info_label"/>
                            <TextView
                                android:id="@+id/textWeight"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- kg"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/medical_info_label"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Height -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/medical_info_divider"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HEIGHT"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="@color/medical_info_label"/>
                            <TextView
                                android:id="@+id/textHeight"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-- cm"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/medical_info_label"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- App Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="App Settings"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.card.MaterialCardView
            style="@style/InstaCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/guide_detail_surface"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dashboard_card_border"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="8dp">
                
                <!-- Notifications -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_centerVertical="true">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_bell" 
                            app:tint="?attr/colorOnSurface"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Notifications"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginStart="16dp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true"/>
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dashboard_card_border"
                    android:layout_marginHorizontal="20dp"/>

                <!-- Dark Mode -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_centerVertical="true">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_moon"
                            app:tint="?attr/colorOnSurface"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dark Mode"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginStart="16dp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/darkModeSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dashboard_card_border"
                    android:layout_marginHorizontal="20dp"/>

                <!-- Location Access -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="16dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_centerVertical="true">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_map_pin"
                            app:tint="?attr/colorOnSurface"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location Access"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginStart="16dp"/>
                    </LinearLayout>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true"/>
                </RelativeLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Account Actions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Account Actions"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"/>

        <!-- Delete Account Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/InstaCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/medical_blood_bg"
            app:strokeColor="@color/emergency_red"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DANGER ZONE"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"
                    android:textColor="@color/emergency_red"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/deleteAccountButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delete My Account"
                    android:textSize="14sp"
                    android:textColor="@color/emergency_red"
                    app:icon="@drawable/ic_alert_triangle"
                    app:iconTint="@color/emergency_red"
                    app:iconSize="18dp"
                    app:rippleColor="#20EF4444"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:layout_gravity="center_horizontal"
            android:paddingHorizontal="32dp"
            android:paddingVertical="12dp"
            android:text="Log Out"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/emergency_red"
            app:icon="@drawable/ic_logout"
            app:iconTint="@android:color/white"
            app:cornerRadius="24dp"
            app:elevation="4dp"/>

    </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
