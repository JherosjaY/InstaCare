<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- OSN Map View -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Floating Back Button -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnBackFloating"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:foreground="?attr/selectableItemBackground">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_arrow_left"
            app:tint="@color/text_primary"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Floating Back Button (Optional improvement if toolbar is too much) -->
    <!-- Details Card at Bottom -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/detailsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:cardBackgroundColor="#1A1212"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/ivTypeIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_baseline_warning_24"
                    app:tint="#EF4444" />

                <TextView
                    android:id="@+id/tvEmergencyType"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Fire Emergency"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#EF4444" />

                <TextView
                    android:id="@+id/tvCaseRef"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Case: IC-2024-001"
                    android:textSize="12sp"
                    android:textColor="#94A3B8" />
            </TableRow>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#334155"
                android:layout_marginVertical="12dp" />

            <TextView
                android:id="@+id/tvPatientName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jheros Jay Rañola"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#F8FAFC"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvLocationDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Poblacion Zone 1, Valencia City"
                android:textSize="14sp"
                android:textColor="#94A3B8"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavigate"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="START NAVIGATION"
                app:icon="@drawable/ic_navigation"
                app:iconTint="#FFFFFF"
                app:cornerRadius="16dp"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#2563EB"
                android:textColor="#FFFFFF" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
