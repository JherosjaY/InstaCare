<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/dashboard_card_border"
    app:cardBackgroundColor="@color/surface_card">

    <LinearLayout
        android:id="@+id/containerMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground">

        <!-- Avatar Circle -->
        <TextView
            android:id="@+id/tvUserInitial"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/circle_white_bg"
            android:backgroundTint="@color/primary"/>

        <!-- User Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user@email.com"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvUserStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active"
                android:textSize="12sp"
                android:textColor="@color/success_green"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSuspendUser"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="86dp"
                android:layout_height="36dp"
                android:text="Suspend"
                android:textSize="11sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="@color/warning_orange"
                android:textColor="@color/warning_orange"
                app:cornerRadius="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteUser"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="86dp"
                android:layout_height="36dp"
                android:text="Delete"
                android:textSize="11sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="@color/emergency_red"
                android:textColor="@color/emergency_red"
                app:cornerRadius="8dp"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
