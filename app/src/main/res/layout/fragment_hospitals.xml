<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background">

    <!-- Map View Placeholder -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/dashboard_background">
        
        <!-- Real Map View -->
        <org.osmdroid.views.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"/>
    </FrameLayout>



    <!-- Header (Overlay) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="@drawable/bg_topbar_surface_rounded"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvTitleHospitals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nearby Facilities"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stay safe today."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/refreshCard"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_refresh"
                android:layout_gravity="center"
                app:tint="@color/emergency_red"/>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Sheet -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/surface_card"
        app:strokeWidth="0dp"
        app:cardElevation="0dp"
        app:behavior_peekHeight="260dp"
        app:behavior_expandedOffset="100dp"
        app:behavior_fitToContents="false"
        app:behavior_hideable="true"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            
            <View
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_drag_handle"/>

            <!-- Main Filter Chips -->
            <!-- Main Filter Chips (Centered) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:chipSpacingHorizontal="12dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHospitals"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hospitals"
                        android:checked="true"
                        android:textColor="@color/chip_text_selector"
                        app:chipIcon="@drawable/ic_hospital"
                        app:chipIconTint="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEvacuation"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Evacuation"
                        android:textColor="@color/chip_text_selector"
                        app:chipIcon="@drawable/ic_home"
                        app:chipIconTint="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <!-- Disaster Sub-Filter Chips (Visible when Evacuation is selected) -->
            <HorizontalScrollView
                android:id="@+id/scrollDisasterFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="24dp"
                android:clipToPadding="false"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupDisasterFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:chipSpacingHorizontal="8dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDisasterAll"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        android:checked="true"
                        android:textColor="@color/chip_text_selector"
                        app:chipIcon="@drawable/ic_check"
                        app:chipIconTint="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDisasterFlood"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Flood"
                        android:textColor="@color/chip_text_selector"
                        app:chipIcon="@drawable/ic_storm"
                        app:chipIconTint="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDisasterEarthquake"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Earthquake"
                        android:textColor="@color/chip_text_selector"
                        app:chipIcon="@drawable/ic_alert_triangle"
                        app:chipIconTint="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDisasterFire"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fire"
                        android:textColor="@color/chip_text_selector"
                        app:chipIcon="@drawable/ic_fire"
                        app:chipIconTint="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDisasterTyphoon"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Typhoon"
                        android:textColor="@color/chip_text_selector"
                        app:chipIcon="@drawable/ic_storm"
                        app:chipIconTint="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDisasterVolcano"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Volcano"
                        android:textColor="@color/chip_text_selector"
                        app:chipIcon="@drawable/ic_alert_triangle"
                        app:chipIconTint="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- Loading State -->
            <LinearLayout
                android:id="@+id/loadingStateHospitals"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                <ProgressBar
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:indeterminateTint="@color/primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Fetching nearby facilities..."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>
            </LinearLayout>
            
            <LinearLayout
                android:id="@+id/emptyStateHospitals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_map_pin"
                    app:tint="@color/primary"
                    android:layout_marginBottom="16dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Facilities Found"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="We couldn't find any nearby hospitals."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/hospitalsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="16dp"
                android:paddingBottom="130dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_hospital"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Custom Compass Container -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/navFabContainer"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/secondary_light"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">
        
        <ImageView
            android:id="@+id/navFabIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_navigation"
            app:tint="@android:color/white"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Detailed Compass Overlay -->
    <FrameLayout
        android:id="@+id/compassOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:elevation="20dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/compassDialContainer"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="#1AFFFFFF"
            app:cardCornerRadius="140dp"
            app:cardElevation="0dp"
            app:strokeColor="#40FFFFFF"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:id="@+id/compassDial"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- North -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginTop="16dp"
                    android:text="N"
                    android:textColor="#EF4444"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- South -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentBottom="true"
                    android:layout_marginBottom="16dp"
                    android:text="S"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- East -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="16dp"
                    android:text="E"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- West -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="16dp"
                    android:text="W"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Pointer -->
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerInParent="true"
                    android:src="@drawable/ic_navigation"
                    app:tint="#EF4444"/>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="100dp"
            android:text="Tap to close"
            android:textColor="#B3FFFFFF"
            android:textSize="14sp" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
