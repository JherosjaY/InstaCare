<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="12dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Request Barangay Endorsement"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fill in the details for your endorsement request"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="12dp"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Patient Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/InstaInput"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editPatientName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Patient Name"
                    android:inputType="textPersonName"
                    android:textCursorDrawable="@drawable/bg_cursor_red"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Address -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/InstaInput"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Complete Address"
                    android:inputType="textPostalAddress|textCapWords"
                    android:textCursorDrawable="@drawable/bg_cursor_red"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Purpose Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/InstaDropdownInput">

                <AutoCompleteTextView
                    android:id="@+id/spinnerPurpose"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select Purpose"
                    android:inputType="none"
                    android:textCursorDrawable="@drawable/bg_cursor_red"
                    android:popupBackground="@color/dashboard_surface"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Hospital -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/InstaDropdownInput">

                <AutoCompleteTextView
                    android:id="@+id/spinnerHospital"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Target Hospital / Facility"
                    android:inputType="none"
                    android:textCursorDrawable="@drawable/bg_cursor_red"
                    android:popupBackground="@color/dashboard_surface"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Reason -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/InstaInput"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Reason / Medical Need"
                    android:inputType="textMultiLine|textCapWords"
                    android:minLines="2"
                    android:maxLines="3"
                    android:textCursorDrawable="@drawable/bg_cursor_red"
                    android:gravity="top"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitEndorsement"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Submit Request"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/primary"
                app:cornerRadius="14dp"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelEndorsement"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
