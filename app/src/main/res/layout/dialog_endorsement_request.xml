<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="12dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_sheet_handle"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Request Barangay Endorsement"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Fill in the details for your endorsement request"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="12dp"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Request Type Selector -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="I am requesting for:"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupRequestType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                android:layout_marginBottom="20dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTypeMedical"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medical Assistance"
                    android:checked="true"
                    android:textColor="@color/chip_text_selector"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    app:chipStrokeColor="@color/chip_stroke_color"
                    app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTypeEvac"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Evacuation Help"
                    android:textColor="@color/chip_text_selector"
                    app:chipBackgroundColor="@color/chip_background_selector"
                    app:chipStrokeColor="@color/chip_stroke_color"
                    app:chipStrokeWidth="1dp"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Common Fields -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/InstaInput"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editPatientName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Your Name"
                    android:inputType="textPersonName|textCapWords"
                    android:textCursorDrawable="@drawable/bg_cursor_red"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/InstaInput"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Complete Address / Pickup Point"
                    android:inputType="textPostalAddress|textCapWords"
                    android:textCursorDrawable="@drawable/bg_cursor_red"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Barangay Selection (Common) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/InstaDropdownInput">

                <AutoCompleteTextView
                    android:id="@+id/spinnerBarangay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select Barangay"
                    android:inputType="none"
                    android:textCursorDrawable="@drawable/bg_cursor_red"
                    android:popupBackground="@color/dashboard_surface"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- MEDICAL ONLY FIELDS -->
            <LinearLayout
                android:id="@+id/layoutMedicalFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InstaDropdownInput">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerPurpose"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Select Purpose"
                        android:inputType="none"
                        android:textCursorDrawable="@drawable/bg_cursor_red"
                        android:popupBackground="@color/dashboard_surface"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    style="@style/InstaDropdownInput">

                    <AutoCompleteTextView
                        android:id="@+id/spinnerHospital"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Target Hospital / Facility"
                        android:inputType="none"
                        android:textCursorDrawable="@drawable/bg_cursor_red"
                        android:popupBackground="@color/dashboard_surface"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- EVACUATION ONLY FIELDS -->
            <LinearLayout
                android:id="@+id/layoutEvacFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disaster Type"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupEvacDisaster"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEvacFlood"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Flood"
                        android:checked="true"
                        android:textColor="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/chip_stroke_color"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEvacEarthquake"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Earthquake"
                        android:textColor="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/chip_stroke_color"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEvacFire"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fire"
                        android:textColor="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/chip_stroke_color"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEvacTyphoon"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Typhoon"
                        android:textColor="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/chip_stroke_color"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>
                </com.google.android.material.chip.ChipGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Special Needs"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupEvacSpecial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEvacNone"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="None"
                        android:checked="true"
                        android:textColor="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/chip_stroke_color"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEvacElderly"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Elderly"
                        android:textColor="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/chip_stroke_color"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEvacPWD"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PWD"
                        android:textColor="@color/chip_text_selector"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/chip_stroke_color"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconVisible="false"/>
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <!-- Reason -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                style="@style/InstaInput"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Reason / Medical Need"
                    android:inputType="textMultiLine|textCapWords"
                    android:minLines="2"
                    android:maxLines="3"
                    android:textCursorDrawable="@drawable/bg_cursor_red"
                    android:gravity="top"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitEndorsement"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Submit Request"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/primary"
                app:cornerRadius="14dp"
                android:layout_marginBottom="4dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelEndorsement"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
