<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/surface_card"
        app:strokeWidth="1dp"
        app:strokeColor="@color/dashboard_card_border">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivLangeCaraAvatar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/cara_avatar"
                    android:scaleType="centerCrop"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/primary"
                    app:shapeAppearanceOverlay="@style/CircleAppearanceOverlay"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvLangTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose Language"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:textColor="@color/primary"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvLangContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Convenient language for our conversation:"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="3dp"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dashboard_card_border"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangBisaya"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bisaya"
                    android:textColor="@color/primary"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    android:textStyle="bold"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangTagalog"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tagalog"
                    android:textColor="@color/primary"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangEnglish"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="English"
                    android:textColor="@color/primary"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1dp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
