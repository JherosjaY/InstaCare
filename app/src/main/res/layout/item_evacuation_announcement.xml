<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface_card"
    app:strokeWidth="1dp"
    app:strokeColor="@color/dashboard_card_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Priority stripe + title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/viewPriorityStripe"
                android:layout_width="4dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_badge_pill"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAnnouncementTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Announcement Title"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="2"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvAnnouncementCenter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All Centers"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Priority badge -->
            <TextView
                android:id="@+id/tvAnnouncementPriority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INFO"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:background="@drawable/bg_badge_pill"/>
        </LinearLayout>

        <!-- Message body -->
        <TextView
            android:id="@+id/tvAnnouncementMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Announcement details..."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="10dp"
            android:lineSpacingMultiplier="1.4"
            android:maxLines="3"
            android:ellipsize="end"/>

        <!-- Divider + timestamp -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dashboard_card_border"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/tvAnnouncementTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Just now"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="6dp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
