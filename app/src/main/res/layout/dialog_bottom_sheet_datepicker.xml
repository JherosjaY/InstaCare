<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_drag_handle"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Date"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="24dp"
        android:weightSum="3"
        android:gravity="center">

        <!-- MONTH COLUMN -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <View android:id="@+id/lineMonthTop" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="50dp" android:background="#E0E0E0"/>
            <com.shawnlin.numberpicker.NumberPicker
                android:id="@+id/pickerMonth"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                app:np_dividerColor="@android:color/transparent"
                app:np_textColor="?attr/colorOnSurface"
                app:np_selectedTextColor="?attr/colorOnSurface"
                app:np_textSize="14sp"
                app:np_selectedTextSize="16sp"
                app:np_wheelItemCount="3"/>
            <View android:id="@+id/lineMonthBottom" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="100dp" android:background="#E0E0E0"/>
        </RelativeLayout>

        <!-- DAY COLUMN -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <View android:id="@+id/lineDayTop" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="50dp" android:background="#E0E0E0"/>
            <com.shawnlin.numberpicker.NumberPicker
                android:id="@+id/pickerDay"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                app:np_dividerColor="@android:color/transparent"
                app:np_textColor="?attr/colorOnSurface"
                app:np_selectedTextColor="?attr/colorOnSurface"
                app:np_textSize="14sp"
                app:np_selectedTextSize="16sp"
                app:np_wheelItemCount="3"/>
            <View android:id="@+id/lineDayBottom" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="100dp" android:background="#E0E0E0"/>
        </RelativeLayout>

        <!-- YEAR COLUMN -->
        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <View android:id="@+id/lineYearTop" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="50dp" android:background="#E0E0E0"/>
            <com.shawnlin.numberpicker.NumberPicker
                android:id="@+id/pickerYear"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                app:np_dividerColor="@android:color/transparent"
                app:np_textColor="?attr/colorOnSurface"
                app:np_selectedTextColor="?attr/colorOnSurface"
                app:np_textSize="14sp"
                app:np_selectedTextSize="16sp"
                app:np_wheelItemCount="3"/>
            <View android:id="@+id/lineYearBottom" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="100dp" android:background="#E0E0E0"/>
        </RelativeLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmDate"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        android:text="Confirm"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:backgroundTint="@color/primary"
        app:cornerRadius="14dp"/>
</LinearLayout>
