<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface_card"
    app:strokeWidth="1dp"
    app:strokeColor="@color/dashboard_card_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header: Case Ref + Status Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Status color stripe -->
            <View
                android:id="@+id/viewEvacEndorStripe"
                android:layout_width="4dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_badge_pill"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvEvacEndorCaseRef"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EV-2025-0001"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvEvacEndorName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient Name"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvEvacEndorStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDING"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_badge_pill"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dashboard_card_border"
            android:layout_marginVertical="10dp"/>

        <!-- Details row: Disaster Type + Special Needs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disaster Type"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"/>

                <TextView
                    android:id="@+id/tvEvacEndorDisaster"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flood"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/warning_orange"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Special Needs"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"/>

                <TextView
                    android:id="@+id/tvEvacEndorSpecial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="None"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Assigned Center (shown when status is ASSIGNED+) -->
        <LinearLayout
            android:id="@+id/rowEvacEndorCenter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_marker_evac"
                app:tint="@color/warning_orange"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:id="@+id/tvEvacEndorCenter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Center Name"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Admin Remarks (shown when not empty) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEvacEndorRemarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFF3E0"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvEvacEndorRemarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Admin remarks..."
                android:textSize="12sp"
                android:textColor="@color/warning_text"
                android:padding="10dp"
                android:lineSpacingMultiplier="1.4"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvEvacEndorTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Submitted: Just now"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
