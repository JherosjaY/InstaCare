<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/adminEvacEndorTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_header_rounded"
        android:elevation="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Evacuation Requests"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Review and assign evacuees to centers"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"/>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#FFF3E0"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="10dp" android:gravity="center">
                    <TextView android:id="@+id/tvAdminEvacEndorPendingCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="@color/warning_orange"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pending" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                app:cardBackgroundColor="#E3F2FD"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="10dp" android:gravity="center">
                    <TextView android:id="@+id/tvAdminEvacEndorAssignedCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="#1565C0"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Assigned" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="#E8F5E9"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="10dp" android:gravity="center">
                    <TextView android:id="@+id/tvAdminEvacEndorResolvedCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="@color/success_green"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Resolved" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <!-- Status Filter -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="198dp"
        android:elevation="4dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupAdminEvacEndorFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAdminEvacEndorAll"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="All" android:checked="true" app:checkedIconVisible="false"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAdminEvacEndorPending"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⏳ Pending" app:checkedIconVisible="false"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAdminEvacEndorAssigned"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📍 Assigned" app:checkedIconVisible="false"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAdminEvacEndorArrived"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠 Arrived" app:checkedIconVisible="false"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAdminEvacEndorResolved"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✅ Resolved" app:checkedIconVisible="false"/>
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/adminEvacEndorEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:layout_marginTop="260dp"
        android:visibility="gone">
        <ImageView
            android:layout_width="64dp" android:layout_height="64dp"
            android:src="@drawable/ic_marker_evac"
            app:tint="@color/warning_orange" android:alpha="0.5"
            android:layout_marginBottom="16dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No Requests" android:textSize="18sp" android:textStyle="bold"
            android:textColor="@color/text_primary"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No evacuation requests have been submitted yet."
            android:textSize="13sp" android:textColor="@color/text_secondary"
            android:gravity="center" android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/adminEvacEndorRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:layout_marginTop="248dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
