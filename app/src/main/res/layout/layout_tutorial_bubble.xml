<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="340dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:clipChildren="false"
    android:clipToPadding="false">

    <RelativeLayout
        android:id="@+id/avatarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingVertical="12dp">

        <TextView
            android:id="@+id/tvWaveOuterLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="("
            android:textColor="@color/emergency_red"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_toStartOf="@id/tvWaveLeft"
            android:layout_centerVertical="true"
            android:layout_marginEnd="8dp"
            android:alpha="0"/>

        <TextView
            android:id="@+id/tvWaveLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="("
            android:textColor="@color/emergency_red"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_toStartOf="@id/ivTutorialCara"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:alpha="0"/>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivTutorialCara"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:layout_centerInParent="true"
            android:src="@drawable/cara_avatar"
            android:padding="2dp"
            app:strokeWidth="2.5dp"
            app:strokeColor="@color/emergency_red"
            app:shapeAppearanceOverlay="@style/CircleAppearanceOverlay"
            android:elevation="6dp" />

        <TextView
            android:id="@+id/tvWaveRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=")"
            android:textColor="@color/emergency_red"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_toEndOf="@id/ivTutorialCara"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:alpha="0"/>

        <TextView
            android:id="@+id/tvWaveOuterRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=")"
            android:textColor="@color/emergency_red"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_toEndOf="@id/tvWaveRight"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp"
            android:alpha="0"/>
    </RelativeLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-10dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/emergency_red"
        app:strokeWidth="1dp"
        app:strokeColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="32dp">

            <TextView
                android:id="@+id/tvTutorialMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hi Jj! I'm Cara, your barkada for safety. Let me show you around!"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:gravity="center"
                android:fontFamily="sans-serif-medium" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTutorialNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="Next"
                android:textAllCaps="false"
                android:textColor="@color/emergency_red"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="20dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
