<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="start">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/dashboard_background">

        <!-- Toolbar: dark navy matching sidebar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/adminToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/bg_admin_sidebar_header"
            android:elevation="4dp"
            app:navigationIcon="@drawable/ic_menu"
            app:navigationIconTint="#FFFFFF"
            app:titleTextColor="#FFFFFF"
            app:subtitleTextColor="#A5B4FC"
            app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6"/>

        <!-- Fragment container -->
        <FrameLayout
            android:id="@+id/adminFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </LinearLayout>

    <!-- Navigation Drawer — Dark Navy Sidebar -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#0F172A">

        <com.google.android.material.navigation.NavigationView
            android:id="@+id/adminNavView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#0F172A"
            app:menu="@menu/admin_drawer_menu_main"
            app:headerLayout="@layout/nav_header_admin"
            app:itemTextColor="@color/nav_admin_text"
            app:itemIconTint="@color/nav_admin_text"
            app:itemBackground="@drawable/bg_nav_item_admin"
            app:itemHorizontalPadding="16dp"
            app:itemIconPadding="12dp"/>

        <!-- Logout at bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E293B"
            android:layout_marginHorizontal="16dp"/>

        <LinearLayout
            android:id="@+id/btnLogoutDrawer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="28dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_logout"
                android:tint="#EF4444"
                android:layout_marginEnd="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textSize="15sp"
                android:textColor="#EF4444"
                android:textStyle="bold"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
