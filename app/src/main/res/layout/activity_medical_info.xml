<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/medical_info_background"
    tools:context=".MedicalInfoActivity">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@drawable/bg_medical_header"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnCancel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_close"
            app:tint="@color/medical_info_header_icon"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medical info"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/medical_info_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageView
            android:id="@+id/btnSave"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_check"
            app:tint="@color/medical_info_save_icon"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Title for Section 1 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Basic info"
                android:textColor="@color/medical_info_section"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="8dp"/>

            <!-- Basic Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/medical_info_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <!-- Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">
                        <TextView
                            android:id="@+id/titleName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Name"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <EditText
                            android:id="@+id/editName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="Enter"
                            android:textColorHint="@color/medical_info_hint"
                            android:textColor="@color/medical_info_value"
                            android:textSize="15sp"
                            android:paddingTop="4dp"
                            android:inputType="textPersonName|textCapWords"/>
                        <View
                            android:id="@+id/dividerName"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/medical_info_divider"/>
                    </LinearLayout>

                    <!-- Height -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">
                        <TextView
                            android:id="@+id/titleHeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Height (cm)"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <EditText
                            android:id="@+id/editHeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="Enter"
                            android:textColorHint="@color/medical_info_hint"
                            android:textColor="@color/medical_info_value"
                            android:textSize="15sp"
                            android:paddingTop="4dp"
                            android:inputType="numberDecimal"/>
                        <View
                            android:id="@+id/dividerHeight"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/medical_info_divider"/>
                    </LinearLayout>

                    <!-- Weight -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">
                        <TextView
                            android:id="@+id/titleWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weight (kg)"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <EditText
                            android:id="@+id/editWeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="Enter"
                            android:textColorHint="@color/medical_info_hint"
                            android:textColor="@color/medical_info_value"
                            android:textSize="15sp"
                            android:paddingTop="4dp"
                            android:inputType="numberDecimal"/>
                        <View
                            android:id="@+id/dividerWeight"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/medical_info_divider"/>
                    </LinearLayout>

                    <!-- Address -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">
                        <TextView
                            android:id="@+id/titleAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Address"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <EditText
                            android:id="@+id/editAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="Where you live"
                            android:textColorHint="@color/medical_info_hint"
                            android:textColor="@color/medical_info_value"
                            android:textSize="15sp"
                            android:paddingTop="4dp"
                            android:inputType="textPostalAddress|textCapWords"/>
                        <View
                            android:id="@+id/dividerAddress"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/medical_info_divider"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Personal Attributes Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/medical_info_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <!-- Sex -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnSex"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp">
                        <TextView
                            android:id="@+id/labelSex"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sex"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <TextView
                            android:id="@+id/textSex"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not set"
                            android:textColor="@color/medical_info_accent"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/labelSex"/>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/medical_info_value"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Blood Type -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnBloodType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp">
                        <TextView
                            android:id="@+id/labelBlood"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Blood type"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <TextView
                            android:id="@+id/textBloodTypeVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not set"
                            android:textColor="@color/medical_info_accent"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/labelBlood"/>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/medical_info_value"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Date of Birth -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnDob"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp">
                        <TextView
                            android:id="@+id/labelDob"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date of birth"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <TextView
                            android:id="@+id/textDob"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not set"
                            android:textColor="@color/medical_info_accent"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/labelDob"/>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/medical_info_value"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Organ Donor -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/btnOrganDonor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="16dp">
                        <TextView
                            android:id="@+id/labelDonor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Organ donor"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <TextView
                            android:id="@+id/textOrganDonor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not set"
                            android:textColor="@color/medical_info_accent"
                            android:textSize="14sp"
                            android:layout_marginTop="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/labelDonor"/>
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/medical_info_value"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Title for Section 3 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Health"
                android:textColor="@color/medical_info_section"
                android:textSize="13sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="8dp"/>

            <!-- Health Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/medical_info_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <!-- Medical conditions -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">
                        <TextView
                            android:id="@+id/titleConditions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medical conditions"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <EditText
                            android:id="@+id/editConditions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="Chronic diseases"
                            android:textColorHint="@color/medical_info_hint"
                            android:textColor="@color/medical_info_value"
                            android:textSize="15sp"
                            android:paddingTop="4dp"
                            android:inputType="textMultiLine|textCapWords"
                            android:maxLines="3"/>
                        <View
                            android:id="@+id/dividerConditions"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/medical_info_divider"/>
                    </LinearLayout>

                    <!-- Medications -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">
                        <TextView
                            android:id="@+id/titleMedications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medications"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <EditText
                            android:id="@+id/editMedications"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="Your medications or medical treatments"
                            android:textColorHint="@color/medical_info_hint"
                            android:textColor="@color/medical_info_value"
                            android:textSize="15sp"
                            android:paddingTop="4dp"
                            android:inputType="textMultiLine|textCapWords"
                            android:maxLines="3"/>
                        <View
                            android:id="@+id/dividerMedications"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/medical_info_divider"/>
                    </LinearLayout>

                    <!-- Allergies -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">
                        <TextView
                            android:id="@+id/titleAllergies"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Allergies &amp; reactions"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <EditText
                            android:id="@+id/editAllergies"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="Medications, food, etc."
                            android:textColorHint="@color/medical_info_hint"
                            android:textColor="@color/medical_info_value"
                            android:textSize="15sp"
                            android:paddingTop="4dp"
                            android:inputType="textMultiLine|textCapWords"
                            android:maxLines="3"/>
                        <View
                            android:id="@+id/dividerAllergies"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/medical_info_divider"/>
                    </LinearLayout>

                    <!-- Remarks -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="12dp">
                        <TextView
                            android:id="@+id/titleRemarks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Remarks"
                            android:textColor="@color/medical_info_label"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <EditText
                            android:id="@+id/editRemarks"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="Additional information"
                            android:textColorHint="@color/medical_info_hint"
                            android:textColor="@color/medical_info_value"
                            android:textSize="15sp"
                            android:paddingTop="4dp"
                            android:inputType="textMultiLine|textCapWords"
                            android:maxLines="3"/>
                        <View
                            android:id="@+id/dividerRemarks"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:background="@color/medical_info_divider"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
