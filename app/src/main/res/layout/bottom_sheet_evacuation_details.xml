<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_sheet_handle"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Photo -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDetailPhoto"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:id="@+id/ivDetailPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Name + Status Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/evacDetailName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Evacuation Center"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/evacDetailStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Open"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_badge_pill"/>
            </LinearLayout>

            <TextView
                android:id="@+id/evacDetailType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="School"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp"/>

            <!-- Capacity Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_info_section"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Capacity"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/evacDetailCapacityText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/0"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/evacDetailCapacityBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:max="100"
                    android:progressTint="#2563EB"
                    android:progressBackgroundTint="#E2E8F0"/>
            </LinearLayout>

            <!-- Details Section -->
            <TextView
                android:id="@+id/evacDetailAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:drawablePadding="8dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/evacDetailDistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0.0 km away"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary_light"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/evacDetailCoords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/text_tertiary"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/evacDetailContact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contact"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:drawablePadding="8dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/evacDetailAmenities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Amenities"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp"/>

            <!-- Directions Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDirections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get Directions"
                android:paddingVertical="12dp"
                app:cornerRadius="12dp"
                app:backgroundTint="#2563EB"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                app:icon="@drawable/ic_navigation"
                app:iconTint="@android:color/white"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
