<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sosRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sos_background"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tvSosHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMERGENCY HOTLINES"
        android:textColor="@color/emergency_red"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSosSubHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Valencia City Local Emergency Response"
        android:textColor="@color/sos_subheader"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSosHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Dynamic Hotlines Container -->
    <ScrollView
        android:id="@+id/scrollHotlines"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="24dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tvSosSubHeader"
        app:layout_constraintBottom_toTopOf="@id/btnImSafe">

        <LinearLayout
            android:id="@+id/hotlinesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Buttons dynamically populated by SOSActivity.java -->
        </LinearLayout>
    </ScrollView>

    <!-- Secondary Action (Safety) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnImSafe"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="16dp"
        android:layout_marginHorizontal="16dp"
        android:text="I AM SAFE NOW"
        android:textColor="@color/sos_safe_button_text"
        android:textSize="14sp"
        android:textStyle="bold"
        android:backgroundTint="@color/sos_safe_button_bg"
        app:strokeColor="@color/sos_safe_button_stroke"
        app:strokeWidth="1dp"
        app:cornerRadius="25dp"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
