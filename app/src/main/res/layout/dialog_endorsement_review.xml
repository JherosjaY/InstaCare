<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_drag_handle"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tvReviewTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Review Endorsement"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="24dp" android:layout_marginBottom="16dp">
        <TextView
            android:id="@+id/tvCaseRef"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IC-2026-0001"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_badge_primary_light"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:id="@+id/tvZoneLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Poblacion Zone 1"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:background="@drawable/dashboard_card_border_bg"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <!-- Patient Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Patient"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"/>
        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Patient Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp"/>

        <!-- Purpose -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Purpose"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"/>
        <TextView
            android:id="@+id/tvPurpose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Purpose"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp"/>

        <!-- Hospital -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/btnViewMap">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hospital / Facility"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>
                <TextView
                    android:id="@+id/tvHospital"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hospital"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewMap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="View Map"
                android:textAllCaps="false"
                android:textSize="11sp"
                style="@style/Widget.Material3.Button.TonalButton"
                app:icon="@drawable/ic_navigation"
                app:iconSize="14dp"
                app:iconTint="#2563EB"
                android:textColor="#2563EB"
                app:cornerRadius="20dp"
                android:paddingHorizontal="12dp"
                android:minHeight="32dp"
                android:minWidth="0dp" />
        </RelativeLayout>

        <!-- Address -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"/>
        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp"/>

        <!-- Reason -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reason / Medical Need"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"/>
        <TextView
            android:id="@+id/tvReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reason"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp"/>

        <!-- Status -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current Status"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"/>
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDING"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- Admin Remarks (for decline) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/remarksLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/input_stroke_selector"
            app:hintTextColor="@color/barangay_primary"
            android:hint="Reason for declining...">
 
             <com.google.android.material.textfield.TextInputEditText
                 android:id="@+id/editRemarks"
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 android:inputType="textMultiLine"
                 android:minLines="2"
                 android:maxLines="4"
                 android:textSize="14sp"
                 android:textColor="@color/text_primary"
                 android:textCursorDrawable="@drawable/cursor_blue" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Action Buttons (only visible for PENDING) -->
        <LinearLayout
            android:id="@+id/actionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDecline"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Decline"
                android:textAllCaps="false"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="12dp"
                app:strokeColor="@color/emergency_red"
                android:textColor="@color/emergency_red"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApprove"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Approve"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/success_green"
                app:cornerRadius="12dp"/>
        </LinearLayout>

        <!-- Resolved Message -->
        <LinearLayout
            android:id="@+id/resolvedContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_badge_pill"
            android:backgroundTint="#D1FAE5"
            android:gravity="center"
            android:padding="12dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_circle"
                app:tint="#065F46"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvResolvedMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This Request is Resolved"
                android:textColor="#065F46"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
