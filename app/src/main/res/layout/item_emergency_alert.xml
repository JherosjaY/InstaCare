<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FEF2F2"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#FEE2E2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:id="@+id/iconCircle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/circle_red_bg"
                android:layout_marginEnd="12dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_alarm_active"
                    app:tint="@android:color/white"
                    android:layout_gravity="center"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvCaseRef"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IC-2026-0001"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#DC2626"/>
                <TextView
                    android:id="@+id/tvPatientName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jheros Jay Ranola"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CRITICAL"
                android:textColor="#DC2626"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_pill"
                android:backgroundTint="#FEE2E2"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FEE2E2"
            android:layout_marginVertical="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location / Zone"
                    android:textSize="10sp"
                    android:textColor="#64748B"/>
                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Poblacion Zone 1"
                    android:textSize="13sp"
                    android:textColor="#1E293B"
                    android:textStyle="bold"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewMap"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRACK SOS"
                android:textColor="#DC2626"
                android:textSize="12sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_map_pin"
                app:iconTint="#DC2626"
                app:iconSize="16dp"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/extraInfoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="12dp">

            <View
                android:id="@+id/divider2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#FEE2E2"
                android:layout_marginBottom="12dp"/>

            <!-- GPS Coordinates Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LATITUDE"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="#94A3B8"/>
                    <TextView
                        android:id="@+id/tvLatitude"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7.9120"
                        android:textSize="12sp"
                        android:textColor="#1E293B"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LONGITUDE"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="#94A3B8"/>
                    <TextView
                        android:id="@+id/tvLongitude"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="125.0950"
                        android:textSize="12sp"
                        android:textColor="#1E293B"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Personal Info Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PATIENT DETAILS"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="#94A3B8"/>
                    <TextView
                        android:id="@+id/tvPatientInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Age: 25 | Blood: B+"
                        android:textSize="12sp"
                        android:textColor="#1E293B"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONDITIONS"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="#94A3B8"/>
                    <TextView
                        android:id="@+id/tvConditions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No chronic illness"
                        android:textSize="12sp"
                        android:textColor="#1E293B"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
