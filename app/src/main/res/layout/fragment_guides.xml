<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dashboard_background">

    <!-- Custom Top Bar (Restored from Original) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="@drawable/bg_topbar_surface_rounded"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvTitleGuides"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Aid Guides"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stay safe today."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/bookmarkListCard"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView
                android:id="@+id/btnViewBookmarks"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_bookmark"
                android:layout_gravity="center"
                app:tint="@color/emergency_red"/>
        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Search & Filters Container (Restored from Original) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/dashboard_background">

        <!-- Premium Centered Segmented Toggle: First Aid vs Disaster -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/segmentedControl"
            android:layout_width="280dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_segmented_control"
            android:padding="4dp">

            <!-- The Sliding Indicator -->
            <View
                android:id="@+id/segmentedSlider"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_segmented_slider"
                app:layout_constraintWidth_percent="0.5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:weightSum="2">

                <TextView
                    android:id="@+id/btnTypeFirstAid"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="First Aid"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/btnTypeDisaster"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Disasters"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        
        <com.google.android.material.textfield.TextInputLayout
            style="@style/InstaSearchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false"
            app:endIconMode="custom"
            app:endIconDrawable="@drawable/ic_search"
            app:endIconTint="@color/input_stroke_selector">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/searchEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Search procedures..."/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Dynamic Sub-Categories -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:scrollbars="none">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <!-- First Aid Categories -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/categoryChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:singleSelection="true"
                    app:selectionRequired="true">
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:checked="true"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIconTint="@color/white"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBleeding"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bleeding"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIconTint="@color/white"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipCardiac"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cardiac"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIconTint="@color/white"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipBurn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Burn"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIconTint="@color/white"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipChoking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choking"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIconTint="@color/white"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"/>
                </com.google.android.material.chip.ChipGroup>

                <!-- Disaster Categories -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/disasterCategoryChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:singleLine="true"
                    app:singleSelection="true"
                    app:selectionRequired="true">
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDisasterAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:checked="true"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIconTint="@color/white"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTyphoon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Typhoon"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIconTint="@color/white"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEarthquake"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Earthquake"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIconTint="@color/white"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"/>
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipFire"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fire"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:textColor="@color/chip_text_selector"
                        app:checkedIconTint="@color/white"
                        app:chipBackgroundColor="@color/chip_background_selector"
                        app:chipStrokeColor="@color/dashboard_card_border"
                        app:chipStrokeWidth="1dp"/>
                </com.google.android.material.chip.ChipGroup>
            </FrameLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/guidesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="120dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_guide"/>

        <LinearLayout
            android:id="@+id/emptyStateGuides"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_file_text"
                app:tint="@color/primary"
                android:layout_marginBottom="16dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Guides Yet"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
            <TextView
                android:id="@+id/tvEmptyGuidesMsg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No guides available for this category."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/emptyStateBookmarks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_bookmark"
                app:tint="@color/primary"
                android:layout_marginBottom="16dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Bookmarks Yet"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your saved guides will appear here."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"/>
        </LinearLayout>
    </FrameLayout>

</LinearLayout>
