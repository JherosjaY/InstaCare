<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/dashboard_surface"
    app:strokeWidth="1dp"
    app:strokeColor="@color/dashboard_card_border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Video Thumbnail Container -->
        <FrameLayout
            android:id="@+id/videoThumbnailContainer"
            android:layout_width="match_parent"
            android:layout_height="200dp">
            
            <ImageView
                android:id="@+id/guideThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/motivational_be_prepared"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/onboarding_gradient_overlay"
                android:alpha="0.4"/>

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                app:tint="@color/white"/>

            <!-- Difficulty Tag Overlay -->
            <TextView
                android:id="@+id/tvDifficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_badge_pill"
                android:backgroundTint="#80000000"
                android:text="Medium"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_gravity="top|start"/>
        </FrameLayout>

        <!-- Content Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:id="@+id/tvGuideCategory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Typhoon"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/emergency_red"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>

                    <ImageView
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_marginHorizontal="8dp"
                        android:src="@drawable/bg_dot"
                        app:tint="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15 mins"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvGuideTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Typhoon Survival Basics"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tvGuideDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What to do before, during, and after a severe typhoon."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:lineSpacingMultiplier="1.1"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnBookmarkDisaster"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/circle_red_glow"
                android:src="@drawable/ic_bookmark"
                app:tint="@color/white"
                android:padding="10dp"
                android:elevation="4dp"/>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
