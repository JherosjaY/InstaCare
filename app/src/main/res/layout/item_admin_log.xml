<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/dashboard_card_border"
    app:cardBackgroundColor="@color/surface_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Log Type Badge -->
        <TextView
            android:id="@+id/tvLogType"
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="LOGIN"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/circle_white_bg"
            android:backgroundTint="@color/secondary_light"
            android:paddingVertical="4dp"
            android:paddingHorizontal="6dp"/>

        <!-- Log Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvLogDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User action description"
                android:textSize="13sp"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvLogUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="user@example.com"
                android:textSize="11sp"
                android:textColor="@color/secondary_light"
                android:layout_marginTop="1dp"
                android:textStyle="italic"/>

            <TextView
                android:id="@+id/tvLogTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 mins ago"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="1dp"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
