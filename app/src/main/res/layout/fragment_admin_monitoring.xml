<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Summary Stats (Top Grid) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border"
                app:cardBackgroundColor="@color/surface_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tvTotalLogs" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="24sp" android:textStyle="bold" android:textColor="@color/primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total Logs" android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:textAllCaps="true" android:letterSpacing="0.05"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border"
                app:cardBackgroundColor="@color/surface_card">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp" android:gravity="center">
                    <TextView android:id="@+id/tvSosLogs" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0"
                        android:textSize="24sp" android:textStyle="bold" android:textColor="@color/emergency_red"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SOS Alerts" android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:textAllCaps="true" android:letterSpacing="0.05"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Ranking Sections -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Category Ranking -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Service Request Ranking"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Police -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_shield" app:tint="#3B82F6" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Police Dept" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvRankCountPolice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginEnd="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="calls" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Fire -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_siren" app:tint="#F97316" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fire Dept" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvRankCountFire" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginEnd="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="calls" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Medical -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_heart_pulse" app:tint="#EF4444" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Medical Support" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvRankCountMedical" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginEnd="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="calls" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- Disaster -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_alert_triangle" app:tint="#EAB308" android:layout_marginEnd="12dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Disaster Response" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvRankCountDisaster" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textStyle="bold" android:textColor="@color/text_primary" android:layout_marginEnd="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="calls" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- User Activity Ranking -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top Active Respondents"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border"
                app:cardBackgroundColor="@color/surface_card">

                <LinearLayout
                    android:id="@+id/userRankingContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">
                    <!-- Dynamic user rows will be added here -->
                    <TextView
                        android:id="@+id/tvNoUserActivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="24dp"
                        android:text="No user activity data yet"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:fontStyle="italic"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Detailed Audit Log -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Audit Chronology"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:id="@+id/tvLogCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 entries"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- Filter Chips - Single Line Scrollable -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:scrollbars="none"
                android:overScrollMode="never">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupLogs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLogAll"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        android:checked="true"
                        app:checkedIconTint="@color/chip_icon_white"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLogLogin"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Login"
                        app:checkedIconTint="@color/chip_icon_white"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLogRegister"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Register"
                        app:checkedIconTint="@color/chip_icon_white"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLogSos"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SOS"
                        app:checkedIconTint="@color/chip_icon_white"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipLogBroadcast"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Broadcast"
                        app:checkedIconTint="@color/chip_icon_white"/>

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_card_border"
                app:cardBackgroundColor="@color/surface_card">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="200dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvLogs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"/>

                    <!-- Empty State -->
                    <LinearLayout
                        android:id="@+id/emptyStateLogs"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="gone"
                        android:padding="40dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_alert_triangle"
                            app:tint="@color/primary"
                            android:alpha="0.8"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No Activity Logs"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
